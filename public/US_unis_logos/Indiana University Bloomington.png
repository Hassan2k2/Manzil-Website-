                    <li>
            <div class="rvt-card rvt-card--news">
                                    <div class="rvt-card__image">
                        <picture>
	                        <img alt="" data-max-h="800" data-max-w="1200" data-optimized="true" height="430" loading="lazy" src="https://news.iu.edu/live/image/gid/2/width/600/height/430/crop/1/src_region/0,0,3200,2133/30609_20260521_IUVenturesSummit_WC_1507.JPG" width="600"/>
                        </picture>
