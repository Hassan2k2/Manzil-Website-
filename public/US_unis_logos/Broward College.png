    $( ".help-modal-btn" ).draggable({
        axis:        'y',
        handle: ".help-modal-grab"
    });

</script>

		



        

            

        <script>
     
        function removeBBH() {
          const el = document.getElementById("bbh-chat-wrapper");
          if (el) el.remove();
        }
        
        // Initial removal (in case it already exists)
        removeBBH();
        
        // Watch for future injections
        const observer = new MutationObserver((mutations) => {
          for (const mutation of mutations) {
            for (const node of mutation.addedNodes) {
              if (
                node.nodeType === 1 &&
                (node.id === "bbh-chat-wrapper" ||
                 node.querySelector?.("#bbh-chat-wrapper"))
              ) {
                node.remove();
              }
            }
          }
        });
        
        observer.observe(document.documentElement, {
          childList: true,
          subtree: true
        });
    
    </script>

    <script src="../_files/js/lightbox/lightbox-init.js" type="text/javascript"></script>
    <script src="../_files/js/data-tables/datatables-init.js" type="text/javascript"></script>



