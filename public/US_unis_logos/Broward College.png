	<script>
    
$(".acc-jumplinks a").focus(function() {
    if ($(".c-header__accessible").hasClass("sr-only")) {
//         $(".c-header__accessible").first().removeClass("sr-only");
//         $( ".acc-jumplinks a:first-child" ).focus();

        $(".c-header__accessible").first().css("height", "0px").removeClass("sr-only").animate({height: "48px"}, 250).css("z-index", "unset");
    }
});

</script>
	<script>
document.querySelector('button.acc-close').onclick = function(){

    $(".c-header__accessible").first().animate({height: "0px"}, 250);
    setTimeout(function(){ $(".c-header__accessible").first().addClass("sr-only"); }, 200);
    
};

document.getElementsByClassName('c-header__accessible')[1].remove();
</script>
