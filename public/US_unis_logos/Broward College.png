        -webkit-mask-image: linear-gradient(to bottom, rgba(0, 0, 0, 1) 0%, rgba(0, 0, 0, 1) 70%, rgba(0, 0, 0, 0) 100%);
        max-height: 300px;
        margin-bottom: 1em;
    }
    .truncText.showFull {
        -webkit-mask-image: unset;
        max-height: unset;
    }
