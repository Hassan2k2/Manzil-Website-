    <style>
        .bbh-chat-wrapper {
            right:16px;
        }
        @media only screen and (max-width: 767px) {
            .bbh-chat-wrapper #u8botchatLinkBbh, .bbh-chat-wrapper #bbh-chat-help-msg {
                visibility:hidden;
            }
            .bbh-chat-wrapper #bbh-chat-body {
                bottom:50px !important;
            }
        }
        .bbh-chat-wrapper:not(.active) {
            bottom:25px;
        }
        .bbh-chat-wrapper .chatBT {
            width:70px !important;
            height:70px !important;
        }
        #bbh-chat-help-msg {
            right:-8px;
            bottom: 86px;
        }
        @media only screen and (max-width: 600px) {
            body .bbh-chat-wrapper .chatBT {
                width: 70px !important;
                height: 70px !important;
            }
        }
        @media (max-width: 1024px) and (min-width: 601px) {
            body .bbh-chat-wrapper .chatBT {
                width: 70px !important;
                height: 70px !important;
            }
        }
        
        
        
        .help-modal-icon.desk-alt-format-btn .bg-pseudo {
            background: #c3d156;
            display: flex;
            color: #003478;
            border-radius: 4px;
            -webkit-transition: background .5s;
            transition: background .5s;
            z-index: 1;
            position: relative;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
        }
        
        /*********************** Accessibility animation *********************************/
        .help-modal-icon.desk-alt-format-btn {
          max-width: unset;
          transition: 0.5s;
        }
        
        .help-modal-btn.expose-grab:not(.hidden) .help-modal-icon.desk-alt-format-btn, .ui-draggable-dragging:not(.hidden) .help-modal-icon.desk-alt-format-btn {
          width: 160px;
          
        }
        
        .help-modal-icon.desk-alt-format-btn i {
          transition: 0.5s;
          transition-delay: 0.25s;
        }
        
        .help-modal-btn.expose-grab .help-modal-icon.desk-alt-format-btn i, .ui-draggable-dragging .help-modal-icon.desk-alt-format-btn i {
          transform: scale(0);
          transition-delay: 0s;
        }
        
        .help-modal-icon.desk-alt-format-btn .title {
          position: absolute;
        }
        
        .help-modal-icon.desk-alt-format-btn .title {
          color: #003478;
          font-weight: 600;
        font-size: 16px;
        text-transform: uppercase;
          transition: 0.5s;
          transition-delay: 0s;
        }
        .help-modal-btn:not(.ui-draggable-dragging, .expose-grab) .help-modal-icon.desk-alt-format-btn .title {
            transform: scale(0);
        }
        
        .help-modal-btn.expose-grab .help-modal-icon.desk-alt-format-btn .title, .ui-draggable-dragging .help-modal-icon.desk-alt-format-btn .help-modal-icon.desk-alt-format-btn .title {
          transform: scale(1);
          transition-delay: 0.25s;
        }
        /*********************** Accessibility Size Corrections *****************************************/
        .help-modal-icon.desk-alt-format-btn {
            width:42px;
            height:42px;
            padding:.05em;
        }
        .help-modal-icon.desk-alt-format-btn i {
            height: 24px;
            width: 24px;
        }
        .help-modal-grab {
            height: 42px;
        }
        
        
        
        .help-modal-grab {
            display: flex;
            justify-content: center;
        }
        .help-modal-grab .grab-pattern-container {
            position: relative;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }
        .help-modal-grab .grab-pattern:not(.last) {
            margin-bottom: 3px;
        }
        .help-modal-grab .grab-pattern {
            display: flex;
            width: 9px;
            justify-content: space-between;
        }
        .help-modal-grab i {
            width: 3px;
            height: 3px;
            background: rgb(255, 255, 255);
            border-radius: 50%;
            position: relative;
            left: unset !important;
            top: unset !important;
        }
        
        .help-modal-btn {
        right: -48px;
    }
    .help-modal-grab.mini {
        position: fixed;
        right: -23px;
        height: 42px;
        width: 15px;
        box-shadow: -3px 5px 20px rgb(0 0 0 / 20%);
        border-radius: 4px 0 0 4px;
        transition: right .25s ease-in-out;
        -o-transition: right .25s ease-in-out;
        -ms-transition: right .25s ease-in-out;
        -moz-transition: right .25s ease-in-out;
        -webkit-transition: right .25s ease-in-out;
    }

    .help-modal-grab.mini.active {
