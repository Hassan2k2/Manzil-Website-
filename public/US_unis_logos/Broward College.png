                        <style>
                #login-modal-btn {
                    padding-right:3em !important;
                }
                #login-modal-btn-toggle {
                    position: absolute;
                    height: 100%;
                    width: 2em;
                    top: 0;
                    right: 0;
                    border-radius: 0 4px 4px 0;
                    border-left: 1px solid #005596;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }
                #login-modal-btn-toggle i {
                    font-weight: bold;
                }
                #login-modal {
                    min-width: 300px;
                    position: absolute;
                    background: #fff;
                    top: calc(100% + .5em);
                    right: .5em;
                    border-radius: 8px;
                    box-shadow: 7px 2px 20px 2px rgb(0 0 0 / 40%);
                    padding: 0 0 1.5em;
                    z-index: 9;
                    text-align: center;
                }
                #login-modal .close-container {
                    display: flex;
                    justify-content: end;
                    padding: .5em .5em 0;
                }
                #login-modal .close-container .close {
                    display: flex;
                }
                #login-modal .close-container .close i {
                    padding: .5em;
                    font-size: 24px;
                }
                #login-modal .login-identity {
                    border-bottom: 1px solid rgba(0,0,0,.125);
                    padding: 1em 1em 0;
                }
                #login-modal .login-identity:nth-child(1 of .login-identity) {
                    padding-top: .5em;
                }
                #login-modal .login-identity:last-of-type {
                    border-bottom: 0;
                }
                #login-modal .identity-label {
                    width: 100%;
                    margin-bottom: 1em;
                }
                #login-modal .identity-label h5 {
                    font-size: 20px !important;
                    text-transform: capitalize; 
                }
                #login-modal .login-identity .identity-options {
                    width: 100%;
                    display: flex;
                    justify-content: space-evenly;
                    margin-bottom: .75em;
                }
                #login-modal .login-identity .identity-options .id-option {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    margin: 0 .25em;
                }
                #login-modal .login-identity .identity-options .id-option .id-option-link {
                    display: flex;
                    flex-direction: column;
                    align-items: center;
                    text-decoration: none;
                }
                #login-modal .login-identity .identity-options .id-option .id-option-link:focus .id-option-icon, #login-modal .login-identity .identity-options .id-option .id-option-link:hover .id-option-icon {
                    background-position: 50% 0 !important;
                    moz-transition: all .15s ease-in-out !important;
                    -o-transition: all .15s ease-in-out !important;
                    -webkit-transition: all .15s ease-in-out !important;
                    transition: all .15s ease-in-out !important;
                    background-image: linear-gradient(116.69deg, #c3d156, #c3d156, #a9deed, #a9deed) !important;
                }
                #login-modal .login-identity .identity-options .id-option .id-option-icon {
                    color: #003478;
                    background-image: linear-gradient(116.69deg, #c3d156, #c3d156, #a9deed, #a9deed) !important;
                    moz-transition: all .15s ease-in-out !important;
                    -o-transition: all .15s ease-in-out !important;
                    -webkit-transition: all .15s ease-in-out !important;
                    transition: all .15s ease-in-out !important;
                    background-size: 300% 100% !important;
                    width: fit-content;
                    padding: .5em;
                    border-radius: 4px;
                    aspect-ratio: 1/1;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    margin-bottom: .5em;
                }
                #login-modal .login-identity .identity-options .id-option .id-option-icon i {
                    font-size: 23px;
                }
                #login-modal .login-identity .identity-options .id-option .id-option-label {
                    color: #2a2623;
                    font-size: 12px;
                    font-weight: bold;
                    line-height: 130%;
                    text-transform: capitalize;
                }
                
                
                
                
                
               
                .c-primary-nav-mobile .c-header__secondary .c-header__secondary__ctas.mobile-login .mobile-qbtn-list {
